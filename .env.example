# Which LLM backend to use: "openai" (default), "anthropic", or "ollama"
LLM_PROVIDER=openai

# --- OpenAI (LLM_PROVIDER=openai) ---
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o

# --- Anthropic / Claude (LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Ollama / local models (LLM_PROVIDER=ollama) ---
# Pick a model that supports tool calling, e.g. llama3.1, qwen2.5, mistral-nemo
OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://localhost:11434
